from collections.abc import Iterable
from pathlib import Path
from typing import Self
import os

class URLError(Exception): ...
class EmptyHost(URLError): ...
class IdnaError(URLError): ...
class InvalidPort(URLError): ...
class InvalidIPv4Address(URLError): ...
class InvalidIPv6Address(URLError): ...
class InvalidDomainCharacter(URLError): ...
class RelativeURLWithoutBase(URLError): ...
class RelativeURLWithCannotBeABaseBase(URLError): ...
class SetHostOnCannotBeABaseURL(URLError): ...

class URL:
    cannot_be_a_base: bool
    host: Domain | None
    host_str: str | None
    password: str | None
    path: str
    path_segments: list[str] | None
    port: int | None
    scheme: str
    username: str
    fragment: str | None
    query: str | None
    query_pairs: list[tuple[str, str]]

    def __truediv__(self, other: str) -> Self: ...
    @classmethod
    def parse(cls, input: str, base: Self | None = None) -> Self: ...
    @classmethod
    def parse_with_params(
        cls,
        input: str,
        params: Iterable[tuple[str, str]],
    ) -> Self: ...
    @classmethod
    def from_file_path(cls, path: str | os.PathLike[str]) -> Self: ...
    @classmethod
    def from_directory_path(cls, path: str | os.PathLike[str]) -> Self: ...
    def to_file_path(self) -> Path: ...
    def join(self, other: str) -> Self: ...
    def make_relative(self, other: Self) -> str: ...
    def with_fragment(self, fragment: str | None = None) -> Self: ...
    def with_query(self, query: str | None = None) -> Self: ...
    def without_query(self) -> Self: ...
    def with_scheme(self, scheme: str) -> Self: ...
    def with_host(self, host: str | None = None) -> Self: ...
    def with_path(self, path: str) -> Self: ...
    def with_port(self, port: int | None = None) -> Self: ...
    def with_username(self, username: str) -> Self: ...
    def with_password(self, password: str | None = None) -> Self: ...
    def with_pair(self, key: str, value: str) -> Self: ...
    def with_key_only(self, key: str) -> Self: ...
    def with_pairs(self, pairs: Iterable[tuple[str, str]]) -> Self: ...
    def with_keys_only(self, keys: Iterable[str]) -> Self: ...
    def without_pair(self, key: str) -> Self: ...

class Domain:
    def __init__(self, value: str): ...
